# Hub v0.4 — Environment variables
# Copy to .env.prod and .env.stage, fill in secrets

# PostgreSQL
POSTGRES_DB=hubdb
POSTGRES_USER=hubuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Hub config is in /etc/hub on the host, mounted as volume
# Secrets (bot tokens, SAP) stay in /etc/hub — NOT in env files
