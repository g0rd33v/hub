# server identity
SERVER_NUMBER=2

# master telepath bot - create with @BotFather, paste full token here
TG_BOT_TOKEN=000000000:AA-replace-me

# Cloudflare credentials for DNS automation
#   CF_API_TOKEN: a token with Zone.DNS:Edit permission for labs.vc
#   CF_ZONE_ID:   visible in the Cloudflare dashboard, Overview pane, right column
CF_API_TOKEN=cf-token-replace-me
CF_ZONE_ID=labs-vc-zone-id-replace-me

# Optional: certbot uses this to send cert renewal warnings
ADMIN_EMAIL=admin@labs.vc
