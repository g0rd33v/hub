# Copy to .env and fill in values before running install.sh
#
# Required
# --------
TG_BOT_TOKEN=                # from @BotFather, e.g. 1234567890:AAH...

# Optional (sensible defaults)
# --------
# DOMAIN=hub.labs.co            # public hostname for this hub instance
# PUBLIC_BASE=https://hub.labs.co  # full URL (auto: https://$DOMAIN)
# EMAIL=admin@hub.labs.co       # Let's Encrypt registration (auto: admin@$DOMAIN)
# SERVER_NUMBER=0               # federation id in drafts-registry.json (default 0)

# Cloudflare DNS automation (optional)
# --------
# CF_API_TOKEN=                 # token with Zone.DNS edit on your zone
# CF_ZONE_ID=                   # zone id (Cloudflare dashboard -> API -> zone id)

# Internal overrides (rarely needed)
# --------
# DRAFTS_PORT=3100
# DRAFTS_HOME=/opt/drafts
# DRAFTS_DATA_DIR=/var/lib/drafts
# HUB_DIR=/opt/hub
