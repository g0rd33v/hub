# Copy to .env and fill in values before running install.sh
#
# Required
# --------
SERVER_NUMBER=2
PUBLIC_BASE=https://drafts2.labs.vc
TG_BOT_TOKEN=                # from @BotFather, e.g. 1234567890:AAH...

# Cloudflare (optional — leave empty to set DNS manually)
# --------
CF_API_TOKEN=                # token with Zone.DNS edit permission on labs.vc
CF_ZONE_ID=                  # zone id of labs.vc (Cloudflare dashboard → API → zone id)

# Optional overrides
# --------
DRAFTS_PORT=3100
DRAFTS_HOME=/opt/drafts
DRAFTS_DATA_DIR=/var/lib/drafts
HUB_DIR=/opt/hub
